{
  "name": "bingo-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run build && node --watch dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "load-test": "node scripts/load-test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.5.4"
  }
}
